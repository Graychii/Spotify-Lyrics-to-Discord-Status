# ── Spotify API ────────────────────────────────────────────────────────────────
# Get these from https://developer.spotify.com/dashboard
SPOTIPY_CLIENT_ID=your_spotify_client_id
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret
SPOTIPY_REDIRECT_URI=https://github.com/yourusername

# ── Discord ────────────────────────────────────────────────────────────────────
# Your Discord user token (NOT a bot token) — see README for how to get it
DISCORD_TOKEN=your_discord_token

# ── Features ───────────────────────────────────────────────────────────────────
ENABLE_DISCORD=true
ENABLE_OVERLAY=true
ENABLE_RAINBOW=false
ENABLE_EMOJIS=true
ENABLE_CENSOR=false

# ── Timing ─────────────────────────────────────────────────────────────────────
# Shift lyrics earlier (negative) or later (positive), in steps of 50ms
LYRIC_OFFSET_MS=0

# How many ms to fire Discord BEFORE the overlay (compensates for Discord lag)
DISCORD_LEAD_MS=300

# How long (ms) without a Discord update before forcing a resync
RESYNC_AFTER_MS=4000

# Subtitle bar Y position on screen (set via GUI)
OVERLAY_Y=900

# ── Subtitle appearance ────────────────────────────────────────────────────────
SUBTITLE_COLOR=#ffffff
SUBTITLE_FONT=Helvetica
SUBTITLE_SIZE=25
SUBTITLE_EFFECT=none
SUBTITLE_BG=#000000
SUBTITLE_BG_TRANSPARENT=false
SUBTITLE_ALPHA=0.800
